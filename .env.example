# Copy to .env and edit. Used by docker-compose.yml.

# Host folder that contains your Target Scheduler database (schedulerdb.sqlite).
# Defaults to ./sample_database — drop your DB there, or point this elsewhere.
# The app operates in place: it reads AND writes the database in this folder, taking
# a backup before every write.
TS_DB_DIR=./sample_database

# Gzip pre-write backups (1 = on). Each backup is roughly the size of your whole
# database, so gzip is handy if disk is tight.
TS_ASSISTANT_BACKUP_GZIP=0

# Published host ports. Keep the backend on 8008 unless you also rebuild the
# frontend with VITE_API_BASE (see frontend/Dockerfile).
TS_FRONTEND_PORT=5173
TS_BACKEND_PORT=8008
